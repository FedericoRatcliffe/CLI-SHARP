<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SharpTerminal.UI.Views.MainWindow"
        Title="CLI-SHARP"
        Width="1024" Height="600"
        Background="#1E1E2E"
        Icon="avares://SharpTerminal.UI/icon.png">

    <!-- Root panel: terminal below, overlay above (z-order) -->
    <Panel>
        <DockPanel>
            <!-- Tab bar -->
            <Border DockPanel.Dock="Top" Background="#11111B" Padding="4,0" MinHeight="32">
                <StackPanel x:Name="TabStrip" Orientation="Horizontal" VerticalAlignment="Center" />
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Background="#11111B" Padding="8,2" MinHeight="22">
                <DockPanel>
                    <TextBlock x:Name="StatusLeft" Foreground="#6C7086" FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusRight" Foreground="#6C7086" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               DockPanel.Dock="Right" />
                </DockPanel>
            </Border>

            <!-- Terminal host -->
            <Panel x:Name="TerminalHost" Background="#1E1E2E" />
        </DockPanel>

        <!-- Overlay host (command palette / history search) -->
        <Panel x:Name="OverlayHost" IsVisible="False" />
    </Panel>

</Window>
